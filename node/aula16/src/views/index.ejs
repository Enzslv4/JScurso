<%- include('includes/head') %>

<body>
    <section class="container">
        <h1>
            
            <% if(typeof title !== 'undefined') { %>
                <%= title %>
            <% } %>
            
        </h1>

        <h2><%= description %></h2>
        <h4>
            <% numbers.forEach(num => { %>
                <%= num %>
                <br>
            <% }) %>
        </h4>
        <form action="/" method="post">
            <label>Cliente</label>
            <input type="text" name="username" id="">
            <button>Enviar</button>
        </form>
    </section>
    

    <script src="assets/js/bundle.js"></script>
</body>
</html>